MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ff_arena
NEXT_PUBLIC_BASE_URL=http://localhost:3000
CORS_ORIGINS=*

# Payment gateway keys (get from your payment dashboard)
PAYMENT_SECRET_KEY=your_secret_key_here
NEXT_PUBLIC_PAYMENT_PUBLISHABLE_KEY=your_publishable_key_here
PAYMENT_WEBHOOK_SECRET=your_webhook_secret_here

# Auth
JWT_SECRET=change_me_to_a_long_random_secret

# Admin
ADMIN_EMAIL=admin@ffarena.com
ADMIN_PASSWORD=change_me_to_a_strong_password

# Platform
PLATFORM_COMMISSION_PERCENT=10

# Web Push VAPID keys (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:admin@ffarena.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
